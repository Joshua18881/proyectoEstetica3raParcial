@page "/clientes"
@rendermode InteractiveServer

<PageTitle>Gestión de Clientes - Glamour Spa</PageTitle>

<div style="display: flex; gap: 2rem;">
    <div class="card-estetica" style="flex: 1;">
        <h3 style="color: var(--primary-color);">Registrar Cliente</h3>

        @if (!string.IsNullOrEmpty(mensajeStatus))
        {
            <div style="padding: 0.8rem; background-color: #d4edda; color: #155724; border-radius: 5px; margin-bottom: 1rem;">
                @mensajeStatus
            </div>
        }

        <EditForm Model="nuevoCliente" OnValidSubmit="GuardarCliente">
            <DataAnnotationsValidator />

            <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
                <div>
                    <label>Nombre Completo *</label>
                    <input type="text" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" @bind="nuevoCliente.Nombre" required />
                </div>
                <div>
                    <label>Apellido *</label>
                    <input type="text" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" @bind="nuevoCliente.Apellido" required />
                </div>
                <div>
                    <label>Teléfono</label>
                    <input type="text" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" @bind="nuevoCliente.Telefono" />
                </div>
                <div>
                    <label>Email *</label>
                    <input type="email" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" @bind="nuevoCliente.Email" required />
                </div>

                <button type="submit" class="btn-estetica" style="margin-top: 1rem;">💾 Guardar en Azure SQL</button>
            </div>
        </EditForm>
    </div>

    <div class="card-estetica" style="flex: 2;">
        <h3 style="color: var(--primary-color);">Clientes Registrados</h3>
        <table style="width: 100%; border-collapse: collapse; margin-top: 1rem; text-align: left;">
            <thead>
                <tr style="border-bottom: 2px solid var(--primary-color);">
                    <th style="padding: 0.8rem;">Nombre</th>
                    <th style="padding: 0.8rem;">Teléfono</th>
                    <th style="padding: 0.8rem;">Email</th>
                    <th style="padding: 0.8rem;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (listaClientes == null)
                {
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem; color: var(--text-muted);">Cargando directorio...</td>
                    </tr>
                }
                else if (!listaClientes.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem; color: var(--text-muted);">No hay registros de clientes en la base de datos.</td>
                    </tr>
                }
                else
                {
                    @foreach (var cliente in listaClientes)
                    {
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 0.8rem;">@cliente.Nombre @cliente.Apellido</td>
                            <td style="padding: 0.8rem;">@cliente.Telefono</td>
                            <td style="padding: 0.8rem;">@cliente.Email</td>
                            <td style="padding: 0.8rem;">
                                <button style="background: transparent; border: none; cursor: pointer; color: #F44336;" @onclick="() => EliminarCliente(cliente.ClienteId)">🗑️ Eliminar</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private Cliente nuevoCliente = new Cliente { FechaRegistro = DateTime.Now };
    private List<Cliente> listaClientes = new();
    private string mensajeStatus = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        using var context = DbFactory.CreateDbContext();
        // CORRECCIÓN: Usamos ClienteId
        listaClientes = await context.Clientes.OrderByDescending(c => c.ClienteId).ToListAsync();
    }

    private async Task GuardarCliente()
    {
        using var context = DbFactory.CreateDbContext();

        context.Clientes.Add(nuevoCliente);
        await context.SaveChangesAsync();

        mensajeStatus = "¡Cliente registrado con éxito en la nube! ✨";

        nuevoCliente = new Cliente { FechaRegistro = DateTime.Now };

        await CargarClientes();
    }

    private async Task EliminarCliente(int id)
    {
        using var context = DbFactory.CreateDbContext();
        var cliente = await context.Clientes.FindAsync(id);

        if (cliente != null)
        {
            context.Clientes.Remove(cliente);
            await context.SaveChangesAsync();
            await CargarClientes();
        }
    }
}