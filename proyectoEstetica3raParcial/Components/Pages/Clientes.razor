@page "/clientes"

<PageTitle>Gestión de Clientes</PageTitle>

<div style="display: flex; gap: 2rem;">
    <div class="card-estetica" style="flex: 1;">
        <h3 style="color: var(--primary-color);">Registrar Cliente</h3>
        <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
            <div>
                <label>Nombre *</label>
                <input type="text" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" required />
            </div>
            <div>
                <label>Apellido *</label>
                <input type="text" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" required />
            </div>
            <div>
                <label>Teléfono</label>
                <input type="text" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" />
            </div>
            <div>
                <label>Email *</label>
                <input type="email" style="width: 100%; padding: 0.6rem; border-radius: 5px; border: 1px solid #ccc;" required />
            </div>
            <button class="btn-estetica" style="margin-top: 1rem;">💾 Guardar en Azure SQL</button>
        </div>
    </div>

    <div class="card-estetica" style="flex: 2;">
        <h3 style="color: var(--primary-color);">Clientes Registrados</h3>
        <table style="width: 100%; border-collapse: collapse; margin-top: 1rem; text-align: left;">
            <thead>
                <tr style="border-bottom: 2px solid var(--primary-color);">
                    <th style="padding: 0.8rem;">Nombre</th>
                    <th style="padding: 0.8rem;">Contacto</th>
                    <th style="padding: 0.8rem;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="3" style="text-align: center; padding: 2rem; color: var(--text-muted);">
                        No hay registros de clientes en la base de datos.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>